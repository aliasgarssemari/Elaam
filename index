<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ELAAM | The Sovereign Registry</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Montserrat:wght@100;300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --royal-gold: #D4AF37;
            --deep-obsidian: #0A0A0B;
            --velvet-maroon: #2D0B13;
            --vibrant-gold: #FFD700;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --neon-border: rgba(212, 175, 55, 0.4);
            --text-main: #F4F4F4;
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body, html {
            height: 100%;
            font-family: 'Montserrat', sans-serif;
            background-color: var(--deep-obsidian);
            color: var(--text-main);
            overflow: hidden;
        }

        /* --- DYNAMIC BACKGROUND --- */
        .bg-canvas {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at center, #1A0F21 0%, #0A0A0B 100%);
            z-index: -1;
        }

        .particles {
            position: absolute; width: 100%; height: 100%;
            background-image: radial-gradient(var(--royal-gold) 1px, transparent 1px);
            background-size: 50px 50px;
            opacity: 0.05;
            animation: move-bg 20s linear infinite;
        }

        @keyframes move-bg {
            0% { background-position: 0 0; }
            100% { background-position: 500px 500px; }
        }

        /* --- LOGIN PAGE --- */
        #login-overlay {
            position: fixed; inset: 0; z-index: 999;
            background: rgba(0,0,0,0.9);
            display: flex; justify-content: center; align-items: center;
            backdrop-filter: blur(20px);
            transition: transform 1s cubic-bezier(1, 0, 0, 1);
        }

        .login-card {
            width: 90%; max-width: 420px;
            background: linear-gradient(135deg, rgba(30, 10, 15, 0.8), rgba(15, 15, 30, 0.8));
            border: 1px solid var(--neon-border);
            border-radius: 40px;
            padding: 50px 40px;
            text-align: center;
            box-shadow: 0 40px 100px rgba(0,0,0,0.8);
            position: relative;
            overflow: hidden;
        }

        .login-card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
            background: linear-gradient(90deg, transparent, var(--royal-gold), transparent);
            animation: shine 3s infinite;
        }

        @keyframes shine { 0%{left:-100%} 100%{left:100%} }

        .logo-elaam {
            font-family: 'Cinzel Decorative', cursive;
            font-size: 3.5rem; color: var(--royal-gold);
            margin-bottom: 10px; text-shadow: 0 0 20px rgba(212,175,55,0.4);
        }

        .login-subtitle { font-size: 0.8rem; letter-spacing: 5px; opacity: 0.5; text-transform: uppercase; margin-bottom: 40px; }

        .login-group { margin-bottom: 20px; text-align: left; }
        .login-group label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--royal-gold); margin-left: 15px; }

        .input-field {
            width: 100%; background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 15px; padding: 18px; color: #fff;
            font-size: 1rem; margin-top: 8px; outline: none; transition: 0.3s;
        }

        .input-field:focus { border-color: var(--royal-gold); background: rgba(255,255,255,0.08); }

        .btn-portal {
            width: 100%; padding: 20px; border: none; border-radius: 15px;
            background: linear-gradient(90deg, #D4AF37, #FFD700);
            color: #000; font-weight: 800; text-transform: uppercase; letter-spacing: 3px;
            cursor: pointer; margin-top: 20px; transition: 0.3s;
        }

        .btn-portal:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(212,175,55,0.3); }

        /* --- DASHBOARD --- */
        #main-app {
            height: 100vh; display: flex; flex-direction: column; opacity: 0; transition: 1s ease 0.5s;
        }

        header {
            padding: 30px 40px; display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .app-title { font-family: 'Cinzel Decorative', cursive; font-size: 2rem; color: var(--royal-gold); }

        /* --- TARGETED SEARCH ENGINE --- */
        .search-engine {
            padding: 40px 20px; max-width: 900px; width: 100%; margin: 0 auto;
        }

        .search-tabs {
            display: flex; justify-content: center; gap: 10px; margin-bottom: 25px;
        }

        .tab-btn {
            padding: 12px 25px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1);
            background: var(--glass-bg); color: #fff; font-size: 0.8rem; cursor: pointer;
            text-transform: uppercase; font-weight: 600; transition: 0.3s;
        }

        .tab-btn.active { background: var(--royal-gold); color: #000; border-color: var(--royal-gold); font-weight: 800; }

        .search-bar-box {
            display: flex; position: relative; gap: 10px;
        }

        .search-bar {
            flex: 1; padding: 22px 30px; border-radius: 20px; border: 2px solid var(--neon-border);
            background: rgba(0,0,0,0.4); color: #fff; font-size: 1.2rem; outline: none; transition: 0.3s;
        }

        .search-bar:focus { border-color: var(--royal-gold); box-shadow: 0 0 30px rgba(212,175,55,0.1); }

        .btn-search {
            padding: 0 35px; border-radius: 20px; border: none; background: var(--royal-gold);
            color: #000; font-weight: 900; cursor: pointer; transition: 0.3s;
        }

        /* --- RESULTS --- */
        #results-container {
            flex: 1; overflow-y: auto; padding: 0 20px 50px;
            display: flex; flex-direction: column; align-items: center;
        }

        .result-card {
            width: 100%; max-width: 700px; background: linear-gradient(145deg, #1A1A1D, #0D0D0F);
            border-radius: 30px; border-left: 8px solid var(--royal-gold);
            padding: 40px; margin-bottom: 30px; animation: popUp 0.6s cubic-bezier(0.18, 0.89, 0.32, 1.28);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            position: relative;
        }

        @keyframes popUp { from{opacity:0; transform:scale(0.9) translateY(40px)} to{opacity:1; transform:scale(1) translateY(0)} }

        .result-name {
            font-family: 'Cinzel Decorative', cursive; font-size: 1.8rem; color: var(--royal-gold);
            margin-bottom: 25px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 15px;
        }

        .data-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 25px;
        }

        .data-item { display: flex; flex-direction: column; }
        .data-label { font-size: 0.7rem; color: var(--royal-gold); text-transform: uppercase; letter-spacing: 2px; opacity: 0.7; margin-bottom: 5px; }
        .data-value { font-size: 1.1rem; font-weight: 600; color: #fff; }

        .action-tray {
            display: flex; gap: 15px; margin-top: 35px; padding-top: 25px;
            border-top: 1px solid rgba(255,255,255,0.05);
        }

        .action-btn {
            flex: 1; padding: 15px; border-radius: 12px; border: 1px solid rgba(212,175,55,0.3);
            background: rgba(255,255,255,0.02); color: #fff; text-decoration: none;
            display: flex; justify-content: center; align-items: center; gap: 10px;
            font-size: 0.8rem; font-weight: 700; transition: 0.3s; cursor: pointer;
        }

        .action-btn:hover { background: var(--royal-gold); color: #000; border-color: var(--royal-gold); }

        .exact-badge {
            position: absolute; top: 20px; right: 20px; padding: 5px 15px;
            background: rgba(0, 255, 136, 0.1); color: #00FF88; border-radius: 50px;
            font-size: 0.6rem; font-weight: 900; letter-spacing: 1px;
        }

        .not-found { font-style: italic; opacity: 0.5; margin-top: 40px; }

        /* Statistics Strip */
        .stats-bar { display: flex; gap: 20px; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
        .stat-box { background: rgba(255,255,255,0.05); padding: 5px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); }
        .stat-box b { color: var(--royal-gold); margin-left: 5px; }

        /* Scrollbar */
        #results-container::-webkit-scrollbar { width: 5px; }
        #results-container::-webkit-scrollbar-thumb { background: var(--royal-gold); border-radius: 10px; }

        /* Mobile Adjustments */
        @media (max-width: 600px) {
            .app-title { font-size: 1.5rem; }
            .stats-bar { display: none; }
            .logo-elaam { font-size: 2.5rem; }
            .data-grid { grid-template-columns: 1fr; }
            .search-bar { font-size: 1rem; padding: 18px 20px; }
            .result-name { font-size: 1.3rem; }
            .action-tray { flex-direction: column; }
        }
    </style>
</head>
