        let currentSearchType = 'form';

        function unlockPortal() {
            const u = document.getElementById('username').value.toLowerCase();
            const p = document.getElementById('pin').value;
            if(u === "elaam" && p === "5253") {
                document.getElementById('login-overlay').style.transform = "translateY(-100%)";
                document.getElementById('main-app').style.opacity = "1";
            } else {
                document.getElementById('error-msg').style.display = "block";
                setTimeout(() => document.getElementById('error-msg').style.display = "none", 2000);
            }
        }

        function setSearchType(type, el) {
            currentSearchType = type;
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            const ph = type === 'name' ? "Enter full or partial name..." : "Enter exact number...";
            document.getElementById('main-query').placeholder = ph;
            document.getElementById('main-query').focus();
        }

        function executeSearch() {
            const query = document.getElementById('main-query').value.trim().toLowerCase();
            const container = document.getElementById('results-container');
            const countBox = document.getElementById('results-count');
            
            if(!query) { container.innerHTML = ""; countBox.innerHTML = "Search<b>EMPTY</b>"; return; }

            let matches = [];

            if(currentSearchType === 'form') {
                // Exact match for Form No
                matches = ELAAM_DB.filter(p => p['FORM NO'].toString().toLowerCase() === query);
            } else if(currentSearchType === 'its') {
                // Exact match for ITS No
                matches = ELAAM_DB.filter(p => p['ITS NO'].toString().toLowerCase() === query);
            } else {
                // Fuzzy/Include for Name
                matches = ELAAM_DB.filter(p => p['NAME'].toLowerCase().includes(query));
            }

            countBox.innerHTML = `Found<b>${matches.length}</b>`;

            if(matches.length > 0) {
                container.innerHTML = matches.map(p => `
                    <div class="result-card">
                        <span class="exact-badge">EXACT MATCH</span>
                        <div class="result-name">${p.NAME}</div>
                        <div class="data-grid">
                            <div class="data-item"><span class="data-label">Form Number</span><span class="data-value">#${p['FORM NO']}</span></div>
                            <div class="data-item"><span class="data-label">ITS Identity</span><span class="data-value">${p['ITS NO']}</span></div>
                            <div class="data-item"><span class="data-label">Seat Row</span><span class="data-value">Row ${p['Shehrullah Seat Row']}</span></div>
                            <div class="data-item"><span class="data-label">Seat Number</span><span class="data-value">${p['Shehrullah Seat No.']}</span></div>
                            <div class="data-item"><span class="data-label">Batch</span><span class="data-value">Batch ${p['Batch No.']}</span></div>
                            <div class="data-item"><span class="data-label">Gender</span><span class="data-value">${p['F / M']}</span></div>
                        </div>
                        <div class="action-tray">
                            <a href="tel:${p['CONTACT NO']}" class="action-btn">📞 CALL NOW</a>
                            <a href="https://wa.me/${p['CONTACT NO']}" target="_blank" class="action-btn">💬 WHATSAPP</a>
                            <button class="action-btn" onclick="window.print()">🖨️ PRINT SLIP</button>
                        </div>
                    </div>
                `).join('');
            } else {
                container.innerHTML = `<p class="not-found">No registry found for your target criteria.</p>`;
            }
        }
